generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Polla {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  fixtureId Int
  homeTeam  String
  awayTeam  String
  homeLogo  String?
  awayLogo  String?
  matchDate DateTime
  status    String   @default("DRAFT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bets      Bet[]
  snapshots MatchSnapshot[]
}

model Bet {
  id              String   @id @default(cuid())
  pollaId         String
  participantName String
  homeScore       Int
  awayScore       Int
  amount          Float
  createdAt       DateTime @default(now())

  polla Polla @relation(fields: [pollaId], references: [id], onDelete: Cascade)

  @@index([pollaId])
}

model MatchSnapshot {
  id              String   @id @default(cuid())
  pollaId         String
  homeScore       Int      @default(0)
  awayScore       Int      @default(0)
  minute          Int?
  status          String
  homePossession  Int?
  awayPossession  Int?
  likelyWinner    String?
  holdProbability Float?
  fetchedAt       DateTime @default(now())

  polla Polla @relation(fields: [pollaId], references: [id], onDelete: Cascade)

  @@index([pollaId, fetchedAt])
}
